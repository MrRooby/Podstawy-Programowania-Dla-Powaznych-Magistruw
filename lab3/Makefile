####### Compile

main_gui.o: src/main_gui.cpp inc/MainWindow.h \
		inc/SimulationController.h \
		inc/ControllerPID.h \
		inc/ObjectSISO.h \
		inc/ModelArx.h \
		inc/Test_ModelARX.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main_gui.o src/main_gui.cpp

ControllerPID.o: src/ControllerPID.cpp inc/ControllerPID.h \
		inc/ObjectSISO.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ControllerPID.o src/ControllerPID.cpp

ModelArx.o: src/ModelArx.cpp inc/ModelArx.h \
		inc/ObjectSISO.h \
		inc/Test_ModelARX.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ModelArx.o src/ModelArx.cpp

MainWindow.o: src/MainWindow.cpp inc/MainWindow.h \
		inc/SimulationController.h \
		inc/ControllerPID.h \
		inc/ObjectSISO.h \
		inc/ModelArx.h \
		inc/Test_ModelARX.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o MainWindow.o src/MainWindow.cpp

SimulationController.o: src/SimulationController.cpp inc/SimulationController.h \
		inc/ControllerPID.h \
		inc/ObjectSISO.h \
		inc/ModelArx.h \
		inc/Test_ModelARX.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o SimulationController.o src/SimulationController.cpp

moc_MainWindow.o: moc_MainWindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_MainWindow.o moc_MainWindow.cpp

